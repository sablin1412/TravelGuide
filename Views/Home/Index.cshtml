@model IEnumerable<TravelGuide.Models.City>
@{
    ViewData["Title"] = "Путеводитель";
}

<div class="container mt-4">
    <h2 class="mb-4">Города России</h2>

    <form asp-controller="Home" asp-action="Index" method="get" class="d-flex mb-4">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
               class="form-control me-2" placeholder="Введите название города (например, москва)..." />
        <button type="submit" class="btn btn-primary me-2">Найти</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Сбросить</a>
    </form>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var city in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@city.Name</h5>
                            <a asp-action="Details" asp-route-id="@city.Id" class="btn btn-sm btn-info text-white w-100">Посмотреть достопримечательности</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning w-100 text-center">
                <strong>Упс!</strong> По вашему запросу "<strong>@ViewData["CurrentFilter"]</strong>" ничего не найдено.
            </div>
        }
    </div>
</div>